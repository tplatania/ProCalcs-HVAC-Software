# ProCalcs PDF Cleaner — Environment Variables
# Copy to .env.local for local development

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Server
PORT=5001
HOST=0.0.0.0

# ODA File Converter path (local install)
# Download from: https://www.opendesign.com/guestfiles/oda_file_converter
ODA_CONVERTER_PATH=

# Upload limits
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=dwg,dxf

# Logging
LOG_LEVEL=INFO
