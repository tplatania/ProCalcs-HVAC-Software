        "common_issues": [
          {
            "model_series": "Infinity / Evolution (User Interface)",
            "issue": "Communication errors (SYSTXCC) often due to ABCD wiring shorts or bad UI connection",
            "years": "2015-Present",
            "field_tip": "Check all low-voltage connections and verify proper wiring sequence"
