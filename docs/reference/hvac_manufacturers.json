          {
            "model_series": "Secondary Heat Exchangers (90%+ Furnaces)",
            "issue": "Polypropylene coating failure leading to clogging/corrosion (Class action history)",
            "years": "1990s-2011",
            "field_tip": "Inspect secondary HX for blockage if experiencing pressure switch issues"
