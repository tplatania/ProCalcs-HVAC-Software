    "diagnostic_troubleshooting": {
      "subcooling": {
        "high_subcooling": {
          "condition": "> 15°F (typical)",
          "indication": "Liquid backing up in condenser",
          "possible_causes": [
            "Overcharged system",
            "Restriction in liquid line (filter drier, kink)",
            "Restriction in metering device (TXV stuck closed)"
          ],
          "fixes": [
            "Recover refrigerant to target weight",
            "Replace liquid line drier",
            "Replace/repair metering device"
          ]
        },
        "low_subcooling": {
          "condition": "< 8°F (typical)",
          "indication": "Not enough liquid in condenser",
          "possible_causes": [
            "Undercharged system",
            "Metering device stuck open (flooding)",
            "Bad compressor valves (low compression)"
          ],
          "fixes": [
            "Add refrigerant (weigh in)",
            "Check TXV bulb placement/replace TXV",
            "Perform compressor efficiency test"
          ]
        }
      },
      "superheat": {
        "high_superheat": {
          "condition": "> 25°F (typical)",
          "indication": "Starved evaporator",
          "possible_causes": [
            "Undercharged system",
            "Liquid line restriction",
            "Metering device restriction",
            "High heat load on evaporator"
          ],
          "fixes": [
            "Leak search and recharge",
            "Replace filter drier",
            "Clear debris from metering device"
          ]
        },
        "low_superheat": {
          "condition": "< 5°F (typical)",
          "indication": "Flooded evaporator (Liquid to compressor risk)",
          "possible_causes": [
            "Overcharged system",
            "Metering device stuck open",
            "Dirty evaporator coil",
            "Low airflow (dirty filter, bad blower)",
            "Oversized equipment"
          ],
          "fixes": [
            "Recover refrigerant",
            "Clean evaporator coil",
            "Replace air filter/adjust blower speed"
          ]
        }
      }
    },
    "symptom_mapping": [
      {
        "symptom": "Warm air from vents",
        "mode": "Cooling",
        "potential_causes": [
          "Compressor not running (capacitor, contactor, thermal overload)",
          "Low refrigerant charge (leak)",
          "Blocked condenser coil",
          "Reversing valve stuck in heating (Heat Pump)"
        ]
      },
      {
        "symptom": "Unit short cycling",
        "mode": "Any",
        "potential_causes": [
          "Low pressure switch cutout (low charge)",
          "High pressure switch cutout (dirty condenser, bad fan)",
          "Oversized unit",
          "Thermostat placement/failure",
          "Clogged condensate drain (float switch trip)"
        ]
      },
      {
        "symptom": "Ice on lines",
        "mode": "Cooling",
        "location": "Suction line / Evaporator",
        "potential_causes": [
          "Low airflow (dirty filter, closed vents)",
          "Low refrigerant charge (low suction pressure drops below freezing)",
          "Blower motor failure",
          "Dirty evaporator coil"
        ]
      },
      {
        "symptom": "High electric bills",
        "mode": "Any",
        "potential_causes": [
          "Dirty coils (reduced heat transfer)",
          "Low refrigerant charge (long run times)",
          "Strip heat stuck on (Heat Pump auxiliary heat)",
          "Compressor failing (high amp draw)",
          "Duct leakage"
        ]
      }
    ]
