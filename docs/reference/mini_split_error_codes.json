  "troubleshooting_guide": {
    "first_questions_to_ask": [
      "What brand and model is your mini-split?",
      "What code is showing and where (indoor display, outdoor LEDs, remote)?",
      "Is it in heating or cooling mode?",
      "Did anything happen recently (power outage, installation, cleaning)?"
    ],
    "universal_first_step": "For most codes: Turn off system, shut off breakers for BOTH indoor and outdoor for 5 minutes, then restore power together.",
    "common_homeowner_fixes": [
      "Communication errors (E1, E6, U4, CH05): Usually outdoor unit lost power - check breaker, power cycle both units",
      "Freeze protection (P6, E2, A5): Dirty filter or blocked airflow - clean filter, check vents, let ice thaw",
      "Mode conflict (CH07): Multi-zone running different modes - set all to same mode",
      "Defrost codes (H1, dF): NORMAL in heating - wait 10-15 minutes"
    ],
    "always_call_pro_for": [
      "Refrigerant leak codes (EC, F0, U0, CH38)",
      "Compressor/inverter codes (P0, P4, H5, UP, F0)",
      "Repeated electrical codes after reset",
      "Any code that returns after power cycle"
    ]
