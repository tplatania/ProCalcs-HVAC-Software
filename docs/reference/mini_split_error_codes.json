  "global_notes": {
    "model_variation_warning": "Error codes can vary by model series, region, control type (wired vs wireless), and generation. Always confirm using the exact model's service manual when available.",
    "how_to_use": [
      "Collect: brand, indoor model number, outdoor model number, the exact code/pattern shown, and whether the unit is heating/cooling/auto.",
      "Ask where the code appears: indoor display/LEDs, outdoor LED board, wired controller, handheld remote, or app.",
      "Run homeowner-safe checks first only when appropriate; stop and call a pro for refrigerant, electrical, or compressor/inverter faults."
    ],
    "safety_overlay_triggers_stop_now": [
      "Burning smell, smoke, or visible arcing",
      "Standing water near electrical components",
      "Refrigerant leak suspected in a small/poorly ventilated space with dizziness/irritation",
      "Any condition that feels unsafe"
