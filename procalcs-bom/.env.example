# ==================================================
# ProCalcs BOM — Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env or .env.local to version control
# ==================================================

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Google Cloud / Firestore
FIRESTORE_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# CORS — comma-separated list of allowed frontend origins.
# Whitespace and empty entries are tolerated.
# Add the Designer Dashboard origin once it calls the BOM service directly.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://procalcs-dashboard-w7vvclyqya-ue.a.run.app

# Admin emails — comma-separated
ADMIN_EMAILS=tom@procalcs.net

# Shared-secret auth — every caller (Designer Desktop BFF, Designer
# Dashboard backend, etc.) must send this exact value in the
# X-Procalcs-Service-Token header. Rotate by changing here + all clients.
# Leave blank to disable the check (dev only).
SERVICE_SHARED_SECRET=change-me-to-a-long-random-string

# Logging
LOG_LEVEL=INFO
